{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "model_id": { "type": "string" },
    "version": { "type": "string" },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number" }
    }
  },
  "required": ["model_id", "version", "inputs"]
}