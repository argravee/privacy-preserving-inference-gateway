{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "model_id": { "type": "string" },
    "version": { "type": "string" },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number" }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["plain"]
        }
      },
      "required": ["mode"]
    }
  },
  "required": ["model_id", "version", "outputs", "diagnostics"]
}